<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TradeLink Manager | SmartView v1.06</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:Arial,Helvetica,sans-serif}
:root{--bg:#08111f;--bg2:#111827;--panel:rgba(24,34,55,.78);--panel2:rgba(17,27,45,.76);--border:rgba(255,255,255,.10);--text:#f8fafc;--muted:#a8b3c7;--blue:#3b82f6;--blue2:#2563eb;--cyan:#06b6d4;--green:#22c55e;--red:#ef4444;--orange:#f59e0b;--shadow:rgba(0,0,0,.32);--soft:rgba(255,255,255,.045);--track:rgba(255,255,255,.12);--logoGlow:rgba(59,130,246,.35)}
html[data-theme="light"]{--bg:#eef4fb;--bg2:#dbeafe;--panel:rgba(255,255,255,.88);--panel2:rgba(248,250,252,.88);--border:rgba(15,23,42,.11);--text:#0f172a;--muted:#475569;--shadow:rgba(15,23,42,.14);--soft:rgba(15,23,42,.045);--track:rgba(15,23,42,.11);--logoGlow:rgba(59,130,246,.20)}
body{min-height:100vh;color:var(--text);background:radial-gradient(circle at 20% 0%,rgba(59,130,246,.18),transparent 32%),radial-gradient(circle at 88% 22%,rgba(6,182,212,.12),transparent 28%),linear-gradient(160deg,var(--bg),var(--bg2));padding:12px;transition:.25s}
.app{max-width:960px;margin:0 auto;padding-bottom:86px}
.hero{display:flex;align-items:center;justify-content:center;padding:12px 2px 15px;border-bottom:1px solid var(--border)}
.logo-img{width:210px;max-width:42vw;height:auto;object-fit:contain;filter:drop-shadow(0 0 20px var(--logoGlow))}

.hero-center{
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
gap:4px;
width:100%;
}

.logo-img{
width:420px;
max-width:92vw;
height:auto;
object-fit:contain;
filter:drop-shadow(0 0 24px rgba(59,130,246,.30));
}

.motto-bottom{
font-size:10px;
letter-spacing:3px;
color:var(--muted);
font-weight:700;
text-transform:uppercase;
margin-top:-2px;
}

@media(max-width:720px){
.logo-img{
width:320px;
max-width:88vw;
}
.motto-bottom{
font-size:8px;
letter-spacing:2px;
}
}

@media(max-width:430px){
.logo-img{
width:270px;
max-width:86vw;
}
.motto-bottom{
font-size:7px;
letter-spacing:1.5px;
}
}

.client-row{margin-top:14px;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:11px 13px;border-radius:24px;border:1px solid var(--border);background:var(--panel);box-shadow:0 14px 34px var(--shadow);backdrop-filter:blur(16px)}
.client-row .left,.client-row .right{font-size:14px;color:var(--muted)}.client-row strong{color:var(--text)}
.avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#334155,#64748b);display:inline-flex;align-items:center;justify-content:center;margin-left:8px;color:#e2e8f0;font-weight:900}
.demo-badge{display:none;margin-left:8px;color:#f59e0b;font-weight:900}
.card{margin-top:14px;border:1px solid var(--border);border-radius:22px;background:var(--panel);box-shadow:0 18px 46px var(--shadow);backdrop-filter:blur(16px);padding:14px;animation:fadeUp .42s ease both}
.card-title{display:flex;align-items:flex-end;justify-content:space-between;gap:10px;margin-bottom:12px}.card-title h2{font-size:17px;line-height:1.1}.card-title span{font-size:12px;color:var(--muted)}
.metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.metric{min-height:112px;padding:12px;border-radius:18px;border:1px solid var(--border);background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.015));position:relative;overflow:hidden}
.metric h3{font-size:14px;color:var(--muted);font-weight:700;margin-bottom:10px}.metric .big{font-size:25px;font-weight:950;letter-spacing:-.4px}.metric .sub{font-size:12px;color:var(--muted);margin-top:7px}
.bar{height:8px;border-radius:999px;background:var(--track);overflow:hidden;margin-top:12px}.bar span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#38bdf8,#bfdbfe)}
.profit-pill{display:inline-flex;align-items:center;justify-content:center;padding:8px 10px;border-radius:12px;background:linear-gradient(135deg,rgba(34,197,94,.82),rgba(22,163,74,.72));box-shadow:0 12px 22px rgba(34,197,94,.20);font-weight:950;font-size:21px}
.ea-box{display:grid;grid-template-rows:1fr 1fr;gap:9px;height:100%}.ea-status{border-radius:16px;background:rgba(34,197,94,.16);border:1px solid rgba(34,197,94,.25);padding:10px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.signal{display:flex;align-items:center;gap:8px;font-weight:900}.dot{width:11px;height:11px;border-radius:50%;background:var(--green);box-shadow:0 0 18px rgba(34,197,94,.95);animation:pulse 1.6s infinite}.dot.pause{background:#9ca3af;box-shadow:0 0 15px rgba(156,163,175,.85)}.dot.stop{background:var(--red);box-shadow:0 0 15px rgba(239,68,68,.85)}
.pulse-icon{font-size:24px;color:#86efac}.eq-trades{border-radius:16px;background:var(--soft);border:1px solid var(--border);padding:10px;font-size:13px}.eq-trades b{font-size:13px}
.snapshot{display:grid;grid-template-columns:1fr auto auto;gap:12px;align-items:center;margin:9px 0 14px}
.spark{height:36px;border-radius:9px;position:relative;overflow:hidden;background:linear-gradient(90deg,rgba(59,130,246,.03),rgba(56,189,248,.14))}
.spark:before{content:"";position:absolute;inset:9px 0 0 0;background:linear-gradient(135deg,transparent 8%,#7dd3fc 20%,transparent 33%,#7dd3fc 44%,#7dd3fc 62%,transparent 73%,#7dd3fc 100%);opacity:.85;clip-path:polygon(0 80%,20% 25%,35% 18%,45% 65%,58% 28%,76% 34%,100% 5%,100% 100%,0 100%)}
.spark.red:before{background:linear-gradient(135deg,transparent,#f87171,transparent,#f87171);clip-path:polygon(0 30%,18% 68%,30% 35%,46% 62%,60% 58%,82% 72%,100% 90%,100% 100%,0 100%)}
.snap-label{font-size:13px;color:var(--muted)}.snap-value{font-size:14px;font-weight:950;text-align:right}
.tabs{display:flex;gap:7px}.tabs button{border:1px solid var(--border);background:var(--soft);color:var(--muted);border-radius:14px;min-height:34px;padding:0 12px;font-size:12px;font-weight:900;cursor:pointer}.tabs button.active{background:var(--blue);color:#fff;box-shadow:0 10px 24px rgba(59,130,246,.28)}
.chart-row{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-top:9px}.chart-box{height:210px;border-radius:18px;border:1px solid var(--border);background:rgba(15,23,42,.26);padding:10px;position:relative}html[data-theme="light"] .chart-box{background:rgba(241,245,249,.65)}canvas{width:100%!important;height:100%!important}
.smart-tip{margin-top:11px;padding:11px 12px;border-radius:18px;background:var(--soft);border:1px solid var(--border);font-size:13px;color:var(--muted);display:flex;gap:9px;align-items:center}
.panel-grid,.service-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.service-grid{margin-top:10px}
.mini-panel{min-height:118px;border:1px solid var(--border);border-radius:18px;background:var(--panel2);padding:12px;display:flex;gap:11px;align-items:center}.mini-panel .icon{width:44px;height:44px;border-radius:14px;background:var(--soft);display:flex;align-items:center;justify-content:center;font-size:25px;color:var(--muted);flex:0 0 auto}
.mini-panel h3{font-size:15px;margin-bottom:7px}.mini-panel p{font-size:12px;color:var(--muted);line-height:1.32}.mini-panel b{color:var(--text)}
.days-pill{margin-left:auto;align-self:center;border-radius:13px;background:rgba(255,255,255,.10);padding:9px 10px;font-size:12px;font-weight:800;text-align:center;white-space:pre-line}
.perf-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}.perf{padding:10px;border-radius:15px;border:1px solid var(--border);background:var(--soft)}.perf .label{font-size:11px;color:var(--muted);margin-bottom:4px}.perf .value{font-size:14px;font-weight:900}
.speed-dial{position:fixed;right:24px;bottom:24px;z-index:100}.dial-list{display:flex;flex-direction:column;gap:8px;align-items:flex-end;margin-bottom:10px;opacity:0;pointer-events:none;transform:translateY(12px);transition:.22s}.speed-dial.open .dial-list{opacity:1;pointer-events:auto;transform:translateY(0)}
.dial-item,.dial-main{border:none;text-decoration:none;color:#fff;background:rgba(59,130,246,.95);border-radius:999px;box-shadow:0 16px 34px rgba(0,0,0,.30);backdrop-filter:blur(14px);font-size:12px;font-weight:950;cursor:pointer;transition:.22s}
.dial-item{min-height:42px;padding:0 14px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.12)}.dial-main{width:62px;height:62px;font-size:30px}.dial-item:hover,.dial-main:hover{transform:translateY(-2px);background:var(--blue2)}.dial-item.red{background:rgba(239,68,68,.92)}.dial-item.ghost{background:rgba(30,41,59,.94)}html[data-theme="light"] .dial-item.ghost{background:rgba(255,255,255,.95);color:#0f172a}
.errorbox{display:none;margin-top:10px;padding:11px;border-radius:14px;border:1px solid rgba(239,68,68,.28);background:rgba(239,68,68,.10);color:#fca5a5;font-size:12px}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}@keyframes pulse{0%,100%{opacity:.45}50%{opacity:1}}
@media(max-width:720px){body{padding:0 0 10px}.app{padding:0 14px 82px}.hero{padding:12px 0;gap:8px}.logo-img{width:165px;max-width:42vw}.motto{font-size:10px;letter-spacing:1.6px}.client-row{margin-top:12px;padding:10px 13px}.client-row .left,.client-row .right{font-size:13px}.avatar{width:32px;height:32px}.card{margin-top:14px;border-radius:20px;padding:14px}.card-title h2{font-size:16px}.metrics{grid-template-columns:1fr 1fr}.metric{min-height:104px;padding:11px}.metric .big{font-size:22px}.metric h3{font-size:13px}.metric.ea-metric{grid-column:span 2;min-height:90px}.ea-box{grid-template-columns:1fr 1fr;grid-template-rows:none}.snapshot{grid-template-columns:.88fr 1fr auto;gap:9px}.spark{height:30px}.tabs button{min-height:32px;padding:0 10px;font-size:11.5px}.chart-box{height:190px}.mini-panel{min-height:105px;padding:11px}.mini-panel .icon{width:38px;height:38px;font-size:21px}.mini-panel h3{font-size:14px}.mini-panel p{font-size:11.5px}.perf-grid{grid-template-columns:repeat(2,1fr)}.speed-dial{right:18px;bottom:18px}.dial-main{width:60px;height:60px}}
@media(max-width:430px){.app{padding:0 13px 76px}.logo-img{width:145px}.motto{font-size:9px;letter-spacing:1.15px}.metrics{gap:8px}.metric{min-height:92px;padding:10px;border-radius:16px}.metric h3{font-size:12px;margin-bottom:8px}.metric .big{font-size:19px}.profit-pill{font-size:18px;padding:7px 9px}.chart-box{height:168px}.panel-grid,.service-grid{gap:8px}.mini-panel{min-height:98px;padding:10px}.mini-panel p{font-size:10.8px}.card{padding:12px}.speed-dial{right:16px;bottom:16px}}
</style>
</head>
<body>
<div class="app">

<header class="hero">
  <div class="hero-center">
    <img src="tradelink_logo_horizontal_premium.png" class="logo-img" alt="TradeLink Manager">
    <div class="motto-bottom">CONNECT • MONITOR • CONTROL • PROFIT</div>
  </div>
</header>


<section class="client-row">
  <div class="left">Client: <strong id="clientNameText">-</strong><span id="demoBadge" class="demo-badge">DEMO</span></div>
  <div class="right">Package: <strong id="packageText">-</strong><span class="avatar">●</span></div>
</section>

<div class="errorbox" id="errorBox"></div>

<section class="card">
  <div class="card-title"><h2>Key Metrics Overview</h2><span>Start optimizing your portfolio.</span></div>
  <div class="metrics">
    <div class="metric"><h3>Balance</h3><div class="big" id="balanceText">0.00</div><div class="bar"><span id="balanceBar" style="width:86%"></span></div><div class="sub">Net Liquidity</div></div>
    <div class="metric"><h3>Floating P/L</h3><div class="profit-pill" id="floatingPLText">0.00</div><div class="bar"><span id="floatingBar" style="width:80%;background:linear-gradient(90deg,#22c55e,#86efac)"></span></div><div class="sub">Open Position Profit/Loss</div></div>
    <div class="metric ea-metric">
      <div class="ea-box">
        <div class="ea-status"><div><div class="label">EA Status</div><div class="signal"><span class="dot" id="eaDot"></span><span id="mt5SignalText">-</span></div></div><div class="pulse-icon">⌁</div></div>
        <div class="eq-trades"><div>Equity & Total Trades</div><b id="equityText">0.00</b> <span id="totalTradesText">0 Trades</span></div>
      </div>
    </div>
  </div>
</section>

<section class="card">
  <div class="card-title"><h2>Portfolio Health & Smart Analytics</h2></div>
  <h2 style="font-size:16px;margin-bottom:8px">Performance Snapshot</h2>
  <div class="snapshot">
    <div class="snap-label">Balance Growth</div><div class="spark"></div><div class="snap-value" id="balanceGrowthText">0%</div>
    <div class="snap-label">Drawdown %</div><div class="spark red"></div><div class="snap-value" id="drawdownText">0%</div>
  </div>
  <div class="perf-grid">
    <div class="perf"><div class="label">Floating %</div><div class="value" id="floatingPercentText">0%</div></div>
    <div class="perf"><div class="label">Profit Today</div><div class="value" id="profitTodayPercentText">0%</div></div>
    <div class="perf"><div class="label">Margin</div><div class="value" id="marginText">0.00</div></div>
    <div class="perf"><div class="label">Positions</div><div class="value" id="positionText">-</div></div>
  </div>
  <div class="chart-row"><h2 style="font-size:16px">Analytics Graph</h2><div class="tabs"><button id="dailyBtn" class="active" onclick="changeAnalytics('daily')">Daily</button><button id="weeklyBtn" onclick="changeAnalytics('weekly')">Weekly</button><button id="monthlyBtn" onclick="changeAnalytics('monthly')">Monthly</button></div></div>
  <div class="chart-box"><canvas id="historyChart"></canvas></div>
  <div class="smart-tip">ⓘ <span id="smartTipText">Portfolio has seen steady growth based on available history data.</span></div>
</section>

<section class="card">
  <div class="card-title"><h2>Activity & Device Panel</h2></div>
  <div class="panel-grid">
    <div class="mini-panel"><div><h3>Signal Status</h3><p><b id="activitySignal">-</b><br><span id="activityUpdate">-</span></p></div></div>
    <div class="mini-panel"><div class="icon">▯</div><div><h3>Device Binding</h3><p>MT5 Login: <b id="mt5AccountLoginText">-</b><br><span id="deviceBindStatusText">-</span></p></div></div>
  </div>
  <div class="service-grid">
    <div class="mini-panel"><div><h3>Service & Expiry</h3><p><b id="licenseStatusText">-</b><br>Expiration Date<br><b id="licenseExpiryText">-</b></p></div><div class="days-pill" id="daysRemainingText">-<br>Days</div></div>
    <div class="mini-panel"><div><h3>Smart Connect</h3><p>MT5 Account <b id="mt5AccountLogin2Text">-</b><br>Name <b id="mt5AccountNameText">-</b><br>SmartView <b>Commercial v1.06</b></p></div></div>
  </div>
</section>
</div>

<div class="speed-dial" id="speedDial">
  <div class="dial-list">
    <a class="dial-item" href="controlpanel.html">Control Panel</a>
    <a class="dial-item" href="analytics.html">Analytics</a>
    <a class="dial-item" href="setting.html">Settings</a>
    <button class="dial-item ghost" onclick="toggleTheme()">Theme</button>
    <button class="dial-item ghost" onclick="toggleBalance()" id="eyeBtn">Hide Balance</button>
    <a class="dial-item ghost" href="EXPANSION/download_center.html">Download</a>
    <a class="dial-item ghost" href="EXPANSION/vps_guide.html">VPS Guide</a>
    <button class="dial-item red" onclick="logout()">Logout</button>
  </div>
  <button class="dial-main" onclick="toggleDial()" id="dialMain">+</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getDatabase, ref, onValue, get } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";
const firebaseConfig={databaseURL:"https://tradelinkmanager-4c8fb-default-rtdb.asia-southeast1.firebasedatabase.app/"};
const app=initializeApp(firebaseConfig);
const db=getDatabase(app);
const clientId=localStorage.getItem("clientId");
let monitorData={},profileData={},licenseData={},historyData={};
let currency="USD",balanceVisible=true,chart,analyticsMode="daily";
if(!clientId) window.location.href="../index.html";
document.documentElement.setAttribute("data-theme",localStorage.getItem("tlTheme")||"dark");
function showError(msg){const box=document.getElementById("errorBox");if(box){box.innerText=msg;box.style.display="block";}}
function safe(v,f="-"){return(v===undefined||v===null||v==="")?f:v}
function set(id,v){const el=document.getElementById(id);if(el)el.textContent=safe(v)}
function money(v){if(!balanceVisible)return"••••";const n=Number(v||0);return currency+" "+n.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}
function plainMoney(v){const n=Number(v||0);return currency+" "+n.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})}
function percent(v){return Number(v||0).toFixed(2)+"%"}
window.toggleDial=function(){const d=document.getElementById("speedDial"),m=document.getElementById("dialMain");d.classList.toggle("open");m.textContent=d.classList.contains("open")?"×":"+"}
window.toggleTheme=function(){const cur=document.documentElement.getAttribute("data-theme")==="dark"?"light":"dark";document.documentElement.setAttribute("data-theme",cur);localStorage.setItem("tlTheme",cur);renderChart()}
window.toggleBalance=function(){balanceVisible=!balanceVisible;set("eyeBtn",balanceVisible?"Hide Balance":"Show Balance");updateMonitor()}
window.logout=function(){localStorage.clear();window.location.href="../index.html"}
function applyEAStatus(status){const dot=document.getElementById("eaDot");const clean=status==="CONNECTED"?"Connected":status==="EA_PAUSE"?"EA Pause":status==="DISCONNECTED"?"Disconnected":(status||"-");set("mt5SignalText",clean);set("activitySignal",clean==="-"?"-":"Active and Synchronized");if(!dot)return;dot.classList.remove("pause","stop");if(status==="EA_PAUSE")dot.classList.add("pause");else if(status!=="CONNECTED")dot.classList.add("stop")}
function activeSymbolsText(m){if(m.active_symbols)return m.active_symbols;if(m.symbols)return Array.isArray(m.symbols)?m.symbols.join(", "):m.symbols;if(m.symbol)return m.symbol;const parts=[];if(Number(m.buy_count||0)>0)parts.push("BUY x"+m.buy_count);if(Number(m.sell_count||0)>0)parts.push("SELL x"+m.sell_count);return parts.length?parts.join(" | "):"No Open Exposure"}
function daysRemaining(expiry){if(!expiry)return"-";const end=new Date(expiry+"T23:59:59");if(isNaN(end.getTime()))return"-";const diff=Math.ceil((end-new Date())/86400000);return diff<0?"Expired":diff}
function updateMonitor(){
 const m=monitorData||{},p=profileData||{},l=licenseData||{};
 currency=m.currency||p.currency||l.currency||"USD";
 set("clientNameText",p.name||localStorage.getItem("clientName")||clientId);set("packageText",p.package||localStorage.getItem("clientPackage")||"-");
 applyEAStatus(m.mt5_signal||"-");set("activityUpdate",m.last_update||"-");
 set("balanceText",money(m.balance));set("equityText",plainMoney(m.equity));
 const pl=Number(m.floating_pl||0);set("floatingPLText",(pl>=0?"+ ":"- ")+money(Math.abs(pl)));set("marginText",money(m.margin));
 set("totalTradesText",(m.total_trades||0)+" Trades");set("positionText",activeSymbolsText(m));
 const plEl=document.getElementById("floatingPLText");if(plEl){plEl.classList.toggle("positive",pl>=0);plEl.classList.toggle("negative",pl<0)}
 const bal=Number(m.balance||0),eq=Number(m.equity||0);const floatingPct=bal>0?(pl/bal)*100:0;const growthPct=bal>0?((eq-bal)/bal)*100:0;
 set("balanceGrowthText",percent(m.balance_growth_percent??growthPct));set("floatingPercentText",percent(m.floating_percent??floatingPct));set("profitTodayPercentText",percent(m.profit_today_percent??0));set("drawdownText",percent(m.drawdown??m.drawdown_percent??0));
 set("licenseStatusText",l.status||l.licenseStatus||"PRO License Active");set("licenseExpiryText",l.expiryDate||"-");set("deviceBindStatusText",l.deviceBindStatus||"Bound to primary device for maximum security.");
 set("mt5AccountLoginText",l.mt5AccountLogin||m.account_login||"-");set("mt5AccountLogin2Text",l.mt5AccountLogin||m.account_login||"-");set("mt5AccountNameText",l.mt5AccountName||m.account_name||"-");set("daysRemainingText",daysRemaining(l.expiryDate)+"\nDays");
 const bar=document.getElementById("floatingBar");if(bar)bar.style.width=Math.max(10,Math.min(100,50+floatingPct)).toFixed(0)+"%";
}
window.changeAnalytics=function(mode){analyticsMode=mode;["daily","weekly","monthly"].forEach(m=>{const b=document.getElementById(m+"Btn");if(b)b.classList.toggle("active",m===mode)});renderChart()}
function buildChartData(){const entries=Object.entries(historyData||{}).sort((a,b)=>a[0].localeCompare(b[0]));if(entries.length===0)return{labels:["No Data"],values:[0]};if(analyticsMode==="daily"){const last=entries.slice(-7);return{labels:last.map(x=>x[0]),values:last.map(x=>Number((x[1]&&(x[1].equity??x[1].balance??x[1].floating_pl))||0))}}if(analyticsMode==="weekly"){const weekly=[];for(let i=0;i<entries.length;i+=7)weekly.push(entries.slice(i,i+7).at(-1));const last=weekly.slice(-8);return{labels:last.map((x,i)=>"W"+(i+1)),values:last.map(x=>Number((x[1]&&(x[1].equity??x[1].balance??x[1].floating_pl))||0))}}const monthlyMap={};entries.forEach(([date,val])=>{monthlyMap[date.slice(0,7)]=val});const monthly=Object.entries(monthlyMap).slice(-12);return{labels:monthly.map(x=>x[0]),values:monthly.map(x=>Number((x[1]&&(x[1].equity??x[1].balance??x[1].floating_pl))||0))}}
function renderChart(){const ctx=document.getElementById("historyChart");if(!ctx||typeof Chart==="undefined")return;const data=buildChartData();const light=document.documentElement.getAttribute("data-theme")==="light";const tick=light?"#475569":"#cbd5e1";const grid=light?"rgba(15,23,42,.08)":"rgba(255,255,255,.08)";if(chart)chart.destroy();chart=new Chart(ctx,{type:"line",data:{labels:data.labels,datasets:[{label:"Equity / Balance",data:data.values,borderWidth:3,tension:.38,fill:true,borderColor:"#7dd3fc",backgroundColor:"rgba(125,211,252,.42)",pointRadius:4,pointHoverRadius:5}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:true}},scales:{x:{ticks:{color:tick,maxTicksLimit:4},grid:{color:grid}},y:{ticks:{color:tick,maxTicksLimit:4},grid:{color:grid}}}}})}
if(localStorage.getItem("isDemo")==="true"){const b=document.getElementById("demoBadge");if(b)b.style.display="inline"}
onValue(ref(db,"TradeLink/clients/"+clientId+"/monitor"),s=>{monitorData=s.val()||{};updateMonitor()},e=>showError("Unable to load monitor data. "+e.message));
onValue(ref(db,"TradeLink/clients/"+clientId+"/profile"),s=>{profileData=s.val()||{};updateMonitor()},e=>showError("Unable to load profile data. "+e.message));
onValue(ref(db,"TradeLink/clients/"+clientId+"/license"),s=>{licenseData=s.val()||{};updateMonitor()},e=>showError("Unable to load license data. "+e.message));
onValue(ref(db,"TradeLink/clients/"+clientId+"/history"),s=>{historyData=s.val()||{};renderChart()},async()=>{try{const s=await get(ref(db,"TradeLink/clients/"+clientId+"/history"));historyData=s.val()||{}}catch(e){}renderChart()});
updateMonitor();renderChart();
</script>
</body>
</html>