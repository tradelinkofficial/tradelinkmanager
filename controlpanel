<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TradeLink Manager | Control Panel</title>

  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:Arial,Helvetica,sans-serif}
    body{min-height:100vh;background:radial-gradient(circle at top,rgba(59,130,246,.18),transparent 34%),linear-gradient(135deg,#0f172a,#111827);color:#f8fafc;padding:18px}
    .container{max-width:1150px;margin:auto}
    .topbar{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:16px;flex-wrap:wrap}
    .brand h1{font-size:24px;letter-spacing:1px;text-shadow:0 0 18px rgba(59,130,246,.7)}
    .brand p{font-size:13px;color:#94a3b8;margin-top:4px}
    .nav{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}
    .nav a,.nav button{border:none;text-decoration:none;padding:11px 15px;border-radius:12px;color:#f8fafc;font-size:13px;font-weight:bold;cursor:pointer;transition:.25s;background:rgba(30,41,59,.78);border:1px solid rgba(255,255,255,.06);box-shadow:0 12px 30px rgba(0,0,0,.18)}
    .nav a:hover,.nav button:hover{background:#1e293b;transform:translateY(-1px)}
    .logoutBtn{background:rgba(239,68,68,.18)!important;color:#fca5a5!important}
    .card{background:rgba(30,41,59,.78);border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:18px;box-shadow:0 20px 50px rgba(0,0,0,.25);backdrop-filter:blur(12px);margin-bottom:16px;animation:fadeIn .5s ease}
    .card h3{color:#94a3b8;font-size:13px;margin-bottom:12px;font-weight:normal;letter-spacing:.3px}
    .profile-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .mini{background:#111827;border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:14px}
    .mini span{display:block;color:#94a3b8;font-size:12px;margin-bottom:6px}
    .mini strong{font-size:16px;color:#f8fafc}
    .package-basic{color:#06b6d4!important}.package-pro{color:#22c55e!important}
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .btn-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .action-btn{width:100%;border:none;border-radius:16px;padding:16px 14px;color:#fff;font-weight:bold;font-size:15px;cursor:pointer;transition:.25s;min-height:58px}
    .action-btn:hover{transform:translateY(-1px);filter:brightness(1.06)}
    .btn-blue{background:#3b82f6}.btn-green{background:#22c55e}.btn-red{background:#ef4444}.btn-orange{background:#f59e0b}.btn-dark{background:#111827;border:1px solid rgba(255,255,255,.08)}
    .action-btn:disabled{background:#334155!important;color:#64748b!important;cursor:not-allowed;transform:none;filter:none}
    .input-row{display:grid;grid-template-columns:1fr auto;gap:10px;margin-bottom:12px;align-items:center}
    .input-row label{grid-column:1 / -1;color:#94a3b8;font-size:13px;margin-bottom:-2px}
    input{width:100%;padding:14px 15px;border-radius:14px;border:1px solid rgba(255,255,255,.08);background:#0f172a;color:#f8fafc;font-size:15px;outline:none;transition:.25s}
    input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.18)}
    .set-btn{border:none;border-radius:14px;padding:14px 16px;color:#fff;font-weight:bold;cursor:pointer;min-width:100px}
    .notice{padding:14px;border-radius:16px;background:rgba(6,182,212,.08);border:1px solid rgba(6,182,212,.2);color:#bae6fd;font-size:13px;line-height:1.5;margin-bottom:16px}
    .locked{display:none;margin-top:12px;padding:12px;border-radius:14px;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.22);color:#fcd34d;font-size:13px}
    .toast{position:fixed;left:50%;bottom:22px;transform:translateX(-50%) translateY(20px);min-width:260px;max-width:calc(100% - 28px);background:#1e293b;border:1px solid rgba(255,255,255,.08);color:#f8fafc;padding:13px 16px;border-radius:14px;box-shadow:0 18px 45px rgba(0,0,0,.35);opacity:0;pointer-events:none;transition:.25s;z-index:20;text-align:center;font-size:14px}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .modal{position:fixed;inset:0;background:rgba(2,6,23,.72);display:none;align-items:center;justify-content:center;padding:20px;z-index:30}
    .modal-box{width:100%;max-width:420px;background:#1e293b;border:1px solid rgba(255,255,255,.08);border-radius:22px;padding:20px;box-shadow:0 25px 80px rgba(0,0,0,.55)}
    .modal-box h3{color:#f8fafc;margin-bottom:8px;font-size:18px}.modal-box p{color:#94a3b8;font-size:14px;line-height:1.5;margin-bottom:18px}
    .modal-actions{display:flex;gap:10px;justify-content:flex-end}.modal-actions button{border:none;border-radius:12px;padding:11px 14px;cursor:pointer;color:#fff;font-weight:bold}
    @keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:900px){.grid{grid-template-columns:1fr}.profile-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:520px){body{padding:14px}.brand h1{font-size:21px}.nav{width:100%}.nav a,.nav button{flex:1;text-align:center}.btn-grid{grid-template-columns:1fr}.profile-grid{grid-template-columns:1fr}.input-row{grid-template-columns:1fr}.set-btn{width:100%}.modal-actions{flex-direction:column}}
  </style>
</head>

<body>
<div class="container">
  <div class="topbar"><div class="brand"><h1>TRADELINK MANAGER</h1><p>DARK TRADING PRO Control Panel MVP v1.00</p></div></div>

  <div class="nav">
    <a href="dashboard.html">Trading Dashboard</a>
    <a href="setting.html">Setting</a>
    <button class="logoutBtn" onclick="logout()">Logout</button>
  </div>

  <div class="card">
    <h3>Client Access</h3>
    <div class="profile-grid">
      <div class="mini"><span>Client ID</span><strong id="clientIdView">-</strong></div>
      <div class="mini"><span>Name</span><strong id="clientName">-</strong></div>
      <div class="mini"><span>Package</span><strong id="clientPackage">-</strong></div>
      <div class="mini"><span>Status</span><strong id="clientStatus">-</strong></div>
    </div>
  </div>

  <div class="notice">
    BASIC package: Close All, Set Stop Loss, Set Take Profit, Set Break Even sahaja.
    PRO package: semua fungsi control panel aktif.
  </div>

  <div class="grid">
    <div class="card">
      <h3>Trading Actions</h3>
      <div class="btn-grid">
        <button class="action-btn btn-red basic-action" onclick="confirmCommand('close_all', true, 'Close All Positions')">Close All</button>
        <button class="action-btn btn-green pro-action" onclick="confirmCommand('close_profit', true, 'Close Profit Positions')">Close Profit</button>
        <button class="action-btn btn-red pro-action" onclick="confirmCommand('close_loss', true, 'Close Loss Positions')">Close Loss</button>
      </div>
      <div class="locked" id="proLockedNotice">PRO functions dikunci untuk BASIC package.</div>
    </div>

    <div class="card">
      <h3>Set SL / TP / BE</h3>
      <div class="input-row"><label>Stop Loss Price</label><input type="number" id="slInput" placeholder="Example: 2500.00" step="0.01"><button class="set-btn btn-red basic-action" onclick="submitNumberCommand('set_sl','slInput','Set Stop Loss')">Set SL</button></div>
      <div class="input-row"><label>Take Profit Price</label><input type="number" id="tpInput" placeholder="Example: 2600.00" step="0.01"><button class="set-btn btn-green basic-action" onclick="submitNumberCommand('set_tp','tpInput','Set Take Profit')">Set TP</button></div>
      <div class="input-row"><label>Break Even Price</label><input type="number" id="beInput" placeholder="Example: 2550.00" step="0.01"><button class="set-btn btn-blue basic-action" onclick="submitNumberCommand('set_be','beInput','Set Break Even')">Set BE</button></div>
    </div>

    <div class="card">
      <h3>PRO Entry Count Control</h3>
      <div class="input-row"><label>Close Low Profit Entry Count</label><input type="number" id="lowProfitInput" placeholder="Example: 5" min="1" step="1"><button class="set-btn btn-orange pro-action" onclick="submitNumberCommand('close_low_profit_count','lowProfitInput','Close Low Profit Count')">Send</button></div>
      <div class="input-row"><label>Close High Profit Entry Count</label><input type="number" id="highProfitInput" placeholder="Example: 5" min="1" step="1"><button class="set-btn btn-green pro-action" onclick="submitNumberCommand('close_high_profit_count','highProfitInput','Close High Profit Count')">Send</button></div>
    </div>

    <div class="card">
      <h3>Command Status</h3>
      <div class="profile-grid">
        <div class="mini"><span>Last Command</span><strong id="lastCommand">-</strong></div>
        <div class="mini"><span>Updated At</span><strong id="updatedAt">-</strong></div>
      </div>
    </div>
  </div>
</div>

<div class="modal" id="confirmModal">
  <div class="modal-box">
    <h3 id="modalTitle">Confirm Action</h3>
    <p id="modalMessage">Are you sure?</p>
    <div class="modal-actions">
      <button class="btn-dark" onclick="closeModal()">Cancel</button>
      <button class="btn-red" id="confirmBtn">Confirm</button>
    </div>
  </div>
</div>

<div class="toast" id="toast">Command sent.</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getDatabase, ref, onValue, update } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";

  const firebaseConfig = { databaseURL: "https://tradelinkmanager-4c8fb-default-rtdb.asia-southeast1.firebasedatabase.app/" };
  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  const clientId = localStorage.getItem("clientId");
  if(!clientId){ window.location.href = "index.html"; }

  const profileRef = ref(db, "TradeLink/clients/" + clientId + "/profile");
  const commandRef = ref(db, "TradeLink/clients/" + clientId + "/command");

  let clientPackage = "BASIC";
  let pendingAction = null;

  document.getElementById("clientIdView").innerText = clientId;

  function nowText(){
    const d = new Date();
    const pad = n => String(n).padStart(2,"0");
    return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate())+" "+pad(d.getHours())+":"+pad(d.getMinutes())+":"+pad(d.getSeconds());
  }

  function showToast(message){
    const toast = document.getElementById("toast");
    toast.innerText = message;
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), 2200);
  }

  function setPackageUI(pkg){
    clientPackage = (pkg || "BASIC").toUpperCase();
    const packageEl = document.getElementById("clientPackage");
    packageEl.innerText = clientPackage;
    packageEl.className = clientPackage === "PRO" ? "package-pro" : "package-basic";
    const isPro = clientPackage === "PRO";
    document.querySelectorAll(".pro-action").forEach(el => {
      el.disabled = !isPro;
      el.style.display = isPro ? "" : "none";
    });
    document.getElementById("proLockedNotice").style.display = isPro ? "none" : "block";
  }

  onValue(profileRef, (snapshot) => {
    const data = snapshot.val() || {};
    document.getElementById("clientName").innerText = data.name || "-";
    document.getElementById("clientStatus").innerText = data.status || "-";
    setPackageUI(data.package || "BASIC");
  });

  onValue(commandRef, (snapshot) => {
    const data = snapshot.val() || {};
    document.getElementById("updatedAt").innerText = data.updatedAt || "-";

    let last = "-";
    if(data.close_all) last = "Close All";
    else if(data.close_profit) last = "Close Profit";
    else if(data.close_loss) last = "Close Loss";
    else if(Number(data.set_sl || 0) > 0) last = "Set SL: " + data.set_sl;
    else if(Number(data.set_tp || 0) > 0) last = "Set TP: " + data.set_tp;
    else if(Number(data.set_be || 0) > 0) last = "Set BE: " + data.set_be;
    else if(Number(data.close_low_profit_count || 0) > 0) last = "Close Low Profit: " + data.close_low_profit_count;
    else if(Number(data.close_high_profit_count || 0) > 0) last = "Close High Profit: " + data.close_high_profit_count;
    document.getElementById("lastCommand").innerText = last;
  });

  function canUseCommand(commandKey){
    const basicAllowed = ["close_all","set_sl","set_tp","set_be"];
    if(clientPackage === "PRO") return true;
    return basicAllowed.includes(commandKey);
  }

  async function sendCommand(payload, label){
    try{
      await update(commandRef, {...payload, updatedAt: nowText()});
      showToast(label + " command sent.");
    }catch(error){
      console.error(error);
      showToast("Command failed. Check Firebase rules.");
    }
  }

  window.confirmCommand = function(commandKey, value, label){
    if(!canUseCommand(commandKey)){ showToast("This function requires PRO package."); return; }
    pendingAction = { payload: {[commandKey]: value}, label };
    document.getElementById("modalTitle").innerText = label;
    document.getElementById("modalMessage").innerText = "Confirm to send command: " + label + "?";
    document.getElementById("confirmModal").style.display = "flex";
  };

  window.submitNumberCommand = function(commandKey, inputId, label){
    if(!canUseCommand(commandKey)){ showToast("This function requires PRO package."); return; }
    const input = document.getElementById(inputId);
    const value = Number(input.value);
    if(!value || value <= 0){ showToast("Please enter valid value."); return; }
    pendingAction = { payload: {[commandKey]: value}, label };
    document.getElementById("modalTitle").innerText = label;
    document.getElementById("modalMessage").innerText = "Confirm to send " + label + " value: " + value + "?";
    document.getElementById("confirmModal").style.display = "flex";
  };

  window.closeModal = function(){
    pendingAction = null;
    document.getElementById("confirmModal").style.display = "none";
  };

  document.getElementById("confirmBtn").onclick = async function(){
    if(!pendingAction) return;
    await sendCommand(pendingAction.payload, pendingAction.label);
    closeModal();
  };

  window.logout = function(){
    localStorage.clear();
    window.location.href = "index.html";
  };
</script>
</body>
</html>
